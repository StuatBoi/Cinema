<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox styleClass="root-container" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cineverse.MainController">

    <!-- ═══════════════════════════════ NAV BAR ═══════════════════════════════ -->
    <HBox alignment="CENTER_LEFT" styleClass="navbar">
        <Label styleClass="logo" text="CINEVERSE" />

        <HBox alignment="CENTER_LEFT" styleClass="nav-links">
            <HBox.margin><Insets left="32" /></HBox.margin>
            <Label styleClass="nav-item, nav-active" text="Trang chủ" />
            <Label styleClass="nav-item" text="Phim lẻ" />
            <Label styleClass="nav-item" text="Phim bộ" />
            <Label styleClass="nav-item" text="Anime" />
            <Label styleClass="nav-item" text="TV Shows" />
        </HBox>

        <Region HBox.hgrow="ALWAYS" />

        <!-- Search -->
        <HBox alignment="CENTER_LEFT" styleClass="search-bar">
            <Label styleClass="search-icon" text="🔍" />
            <TextField promptText="Tìm phim..." styleClass="search-field" />
        </HBox>

        <Button styleClass="btn-login" text="Đăng nhập">
            <HBox.margin><Insets left="14" /></HBox.margin>
        </Button>
    </HBox>

    <!-- ═══════════════════════════════ SCROLLABLE CONTENT ═══════════════════════════════ -->
    <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
        <VBox>

            <!-- ─── HERO SECTION ─── -->
            <StackPane minHeight="420" styleClass="hero-section">
                <!-- Background gradient overlay -->
                <VBox maxWidth="1.7976931348623157E308" styleClass="hero-bg" />

                <!-- Content -->
                <HBox alignment="CENTER" spacing="60" styleClass="hero-content">
                    <HBox.margin><Insets bottom="40" left="60" right="60" top="40" /></HBox.margin>

                    <!-- Left text -->
                    <VBox alignment="CENTER_LEFT" spacing="14" HBox.hgrow="ALWAYS">
                        <HBox spacing="8">
                            <Label styleClass="badge-hot" text="HOT" />
                            <Label styleClass="badge-year" text="2024" />
                        </HBox>
                        <VBox spacing="0">
                            <Label styleClass="hero-title-white" text="KHÁM PHÁ THẾ GIỚI" wrapText="true" />
                            <Label styleClass="hero-title-red" text="ĐIỆN ẢNH" wrapText="true" />
                        </VBox>
                        <Label maxWidth="440" styleClass="hero-subtitle" text="Hàng ngàn bộ phim bom tấn, phim bộ hấp dẫn đang chờ bạn khám phá. Cập nhật liên tục mỗi ngày." wrapText="true" />
                        <HBox spacing="12">
                            <Button styleClass="btn-primary" text="▶  Xem ngay" />
                            <Button styleClass="btn-secondary" text="ℹ  Chi tiết" />
                        </HBox>
                    </VBox>

                    <!-- Featured card -->
                    <VBox alignment="CENTER" maxWidth="240" minWidth="200" styleClass="featured-card">
                        <Label alignment="CENTER_RIGHT" styleClass="rating-badge" text="★ 8.2" />
                        <VBox alignment="CENTER" spacing="10" styleClass="featured-inner" VBox.vgrow="ALWAYS">
                            <Label styleClass="featured-icon" text="🎬" />
                            <Label styleClass="featured-label" text="FEATURED" />
                            <Label styleClass="featured-sub" text="Phim nổi bật" />
                        </VBox>
                    </VBox>
                </HBox>
            </StackPane>

            <!-- ─── TRENDING SECTION ─── -->
            <VBox spacing="18" styleClass="section">
                <HBox alignment="CENTER_LEFT">
                    <Label styleClass="section-title" text="📈  PHIM THỊNH HÀNH" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="see-all" text="Xem tất cả ›" />
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="14">
                    <!-- Card 1 -->
                    <VBox fx:id="card1" styleClass="movie-card">
                        <StackPane styleClass="movie-thumb" VBox.vgrow="ALWAYS">
                            <ImageView fx:id="thumb1" fitHeight="240" fitWidth="175" preserveRatio="true" styleClass="thumb-img">
                                <image><Image backgroundLoading="true" url="https://image.tmdb.org/t/p/w300/1XDDXPXGiI8id7MrUxK36ke7gkX.jpg" /></image>
                            </ImageView>
                            <Label styleClass="quality-badge" text="HD" />
                            <Label styleClass="star-badge" text="★ 8.5" />
                        </StackPane>
                        <VBox spacing="3" styleClass="movie-info">
                            <Label styleClass="movie-title" text="Cuộc Chiến Vương Quyền" wrapText="true" />
                            <Label styleClass="movie-meta" text="Hành động • 2024" />
                        </VBox>
                    </VBox>

                    <!-- Card 2 -->
                    <VBox styleClass="movie-card">
                        <StackPane styleClass="movie-thumb" VBox.vgrow="ALWAYS">
                            <ImageView fitHeight="240" fitWidth="175" preserveRatio="true">
                                <image><Image backgroundLoading="true" url="https://image.tmdb.org/t/p/w300/d5NXSklXo0qyIYkgV94XAgMIckC.jpg" /></image>
                            </ImageView>
                            <Label styleClass="quality-badge quality-cam" text="CAM" />
                            <Label styleClass="star-badge" text="★ 7.8" />
                        </StackPane>
                        <VBox spacing="3" styleClass="movie-info">
                            <Label styleClass="movie-title" text="Bóng Ma Quái Khứ" wrapText="true" />
                            <Label styleClass="movie-meta" text="Kinh dị • 2024" />
                        </VBox>
                    </VBox>

                    <!-- Card 3 -->
                    <VBox styleClass="movie-card">
                        <StackPane styleClass="movie-thumb" VBox.vgrow="ALWAYS">
                            <ImageView fitHeight="240" fitWidth="175" preserveRatio="true">
                                <image><Image backgroundLoading="true" url="https://image.tmdb.org/t/p/w300/fiVW06jE7z9F3EpbGgtpBwiwn8U.jpg" /></image>
                            </ImageView>
                            <Label styleClass="quality-badge" text="HD" />
                            <Label styleClass="star-badge" text="★ 8.9" />
                        </StackPane>
                        <VBox spacing="3" styleClass="movie-info">
                            <Label styleClass="movie-title" text="Mùa Hè Năm Ấy" wrapText="true" />
                            <Label styleClass="movie-meta" text="Tình cảm • 2024" />
                        </VBox>
                    </VBox>

                    <!-- Card 4 -->
                    <VBox styleClass="movie-card">
                        <StackPane styleClass="movie-thumb" VBox.vgrow="ALWAYS">
                            <ImageView fitHeight="240" fitWidth="175" preserveRatio="true">
                                <image><Image backgroundLoading="true" url="https://image.tmdb.org/t/p/w300/qNBAXBIQlnOThrVvA6mA2B5ggV6.jpg" /></image>
                            </ImageView>
                            <Label styleClass="quality-badge" text="HD" />
                            <Label styleClass="star-badge" text="★ 9.1" />
                        </StackPane>
                        <VBox spacing="3" styleClass="movie-info">
                            <Label styleClass="movie-title" text="Vượt Ngàn Hà" wrapText="true" />
                            <Label styleClass="movie-meta" text="Viễn tưởng • 2024" />
                        </VBox>
                    </VBox>

                    <!-- Card 5 -->
                    <VBox styleClass="movie-card">
                        <StackPane styleClass="movie-thumb" VBox.vgrow="ALWAYS">
                            <ImageView fitHeight="240" fitWidth="175" preserveRatio="true">
                                <image><Image backgroundLoading="true" url="https://image.tmdb.org/t/p/w300/8Gxv8gSFCU0XGDykEGv7zR1n2ua.jpg" /></image>
                            </ImageView>
                            <Label styleClass="quality-badge quality-fhd" text="FHD" />
                            <Label styleClass="star-badge" text="★ 8.3" />
                        </StackPane>
                        <VBox spacing="3" styleClass="movie-info">
                            <Label styleClass="movie-title" text="Hiệp Sĩ Bóng Đêm" wrapText="true" />
                            <Label styleClass="movie-meta" text="Hành động • 2023" />
                        </VBox>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ─── RECENTLY UPDATED SECTION ─── -->
            <VBox spacing="18" styleClass="section">
                <HBox alignment="CENTER_LEFT">
                    <Label styleClass="section-title" text="🎬  PHIM MỚI CẬP NHẬT" />
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox spacing="6">
                        <Button styleClass="filter-btn" text="Phim lẻ" />
                        <Button styleClass="filter-btn filter-active" text="Phim bộ" />
                    </HBox>
                </HBox>

                <HBox spacing="14">
                    <!-- Recent item 1 -->
                    <HBox spacing="14" styleClass="recent-card" HBox.hgrow="ALWAYS">
                        <StackPane maxHeight="80" maxWidth="70" minHeight="80" minWidth="70" styleClass="recent-thumb">
                            <ImageView fitHeight="80" fitWidth="70" preserveRatio="true">
                                <image><Image backgroundLoading="true" url="https://image.tmdb.org/t/p/w92/74xTEgt7R36Fpocon6SPTpP7R0k.jpg" /></image>
                            </ImageView>
                            <Label styleClass="recent-icon" text="🔥" />
                        </StackPane>
                        <VBox alignment="CENTER_LEFT" spacing="5" HBox.hgrow="ALWAYS">
                            <Label styleClass="recent-title" text="Ngọn Lửa Phương Bắc" />
                            <Label styleClass="recent-meta" text="Tập 12/24 • Cổ trang" />
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label styleClass="recent-badge badge-new" text="MỚI" />
                                <Label styleClass="recent-time" text="2 giờ trước" />
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- Recent item 2 -->
                    <HBox spacing="14" styleClass="recent-card" HBox.hgrow="ALWAYS">
                        <StackPane maxHeight="80" maxWidth="70" minHeight="80" minWidth="70" styleClass="recent-thumb">
                            <ImageView fitHeight="80" fitWidth="70" preserveRatio="true">
                                <image><Image backgroundLoading="true" url="https://image.tmdb.org/t/p/w92/jCh7BL3kkOEJxNgn8e7UAlHPAUK.jpg" /></image>
                            </ImageView>
                            <Label styleClass="recent-icon" text="🧪" />
                        </StackPane>
                        <VBox alignment="CENTER_LEFT" spacing="5" HBox.hgrow="ALWAYS">
                            <Label styleClass="recent-title" text="Bí Ẩn Phòng Thí Nghiệm" />
                            <Label styleClass="recent-meta" text="Tập 8/16 • Khoa học" />
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label styleClass="recent-badge badge-fhd" text="FHD" />
                                <Label styleClass="recent-time" text="8 giờ trước" />
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- Recent item 3 -->
                    <HBox spacing="14" styleClass="recent-card" HBox.hgrow="ALWAYS">
                        <StackPane maxHeight="80" maxWidth="70" minHeight="80" minWidth="70" styleClass="recent-thumb">
                            <ImageView fitHeight="80" fitWidth="70" preserveRatio="true">
                                <image><Image backgroundLoading="true" url="https://image.tmdb.org/t/p/w92/A4j8S6moJS2zNtRR8oWF08gRnL5.jpg" /></image>
                            </ImageView>
                            <Label styleClass="recent-icon" text="🎵" />
                        </StackPane>
                        <VBox alignment="CENTER_LEFT" spacing="5" HBox.hgrow="ALWAYS">
                            <Label styleClass="recent-title" text="Thanh Xuân Rực Rỡ" />
                            <Label styleClass="recent-meta" text="Tập 20/20 • Hoàn tất" />
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label styleClass="recent-badge badge-full" text="Full" />
                                <Label styleClass="recent-time" text="1 ngày trước" />
                            </HBox>
                        </VBox>
                    </HBox>
                </HBox>
            </VBox>

            <!-- ─── FOOTER ─── -->
            <HBox alignment="CENTER_LEFT" styleClass="footer">
                <Label styleClass="footer-logo" text="CINEVERSE" />
                <Label styleClass="footer-copy" text=" © 2024 All rights reserved" />
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="16">
                    <Label styleClass="social-icon" text="f" />
                    <Label styleClass="social-icon" text="𝕏" />
                    <Label styleClass="social-icon" text="◎" />
                </HBox>
            </HBox>

        </VBox>
    </ScrollPane>
</VBox>
